<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Cronômetro Moderno</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      padding: 20px;
    }

    .container {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 30px;
      padding: 60px;
      box-shadow: 0 8px 32px rgba(31, 38, 135, 0.37);
      border: 1px solid rgba(255, 255, 255, 0.18);
      text-align: center;
      max-width: 400px;
      animation: fadeIn 0.8s ease-in-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    h1 {
      font-size: 28px;
      margin-bottom: 40px;
      font-weight: 300;
      letter-spacing: 2px;
      text-transform: uppercase;
      opacity: 0.9;
    }

    .display-container {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 20px;
      padding: 40px;
      margin-bottom: 40px;
      box-shadow: inset 0 2px 10px rgba(0, 0, 0, 0.2);
    }

    .cronometro {
      font-size: 64px;
      font-weight: 300;
      letter-spacing: 3px;
      font-family: 'Courier New', monospace;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.8;
      }
    }

    .buttons-container {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      justify-content: center;
    }

    button {
      padding: 14px 28px;
      font-size: 16px;
      cursor: pointer;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      flex: 1;
      min-width: 100px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
    }

    button:active {
      transform: translateY(0);
    }

    .start {
      background: linear-gradient(135deg, #00d4ff, #0099ff);
      color: white;
    }

    .start:hover {
      background: linear-gradient(135deg, #00e5ff, #00aaff);
    }

    .pause {
      background: linear-gradient(135deg, #ffa500, #ff8c00);
      color: white;
    }

    .pause:hover {
      background: linear-gradient(135deg, #ffb520, #ff9d1f);
    }

    .reset {
      background: linear-gradient(135deg, #ff6b6b, #ee5a52);
      color: white;
    }

    .reset:hover {
      background: linear-gradient(135deg, #ff7c7c, #ff6060);
    }

    @media (max-width: 600px) {
      .container {
        padding: 40px 30px;
      }

      .cronometro {
        font-size: 48px;
      }

      button {
        padding: 12px 20px;
        font-size: 14px;
      }
    }
  </style>
</head>
<body>

  <div class="container">
    <h1>Cronômetro</h1>
    
    <div class="display-container">
      <div class="cronometro" id="display">00:00:000</div>
    </div>

    <div class="buttons-container">
      <button class="start" onclick="iniciar()">▶ Iniciar</button>
      <button class="pause" onclick="pausar()">⏸ Pausar</button>
      <button class="reset" onclick="resetar()">⟲ Resetar</button>
    </div>
  </div>

  <script>
    let inicio = 0;
    let tempoDecorrido = 0;
    let rodando = false;
    let intervalo;

    function atualizarDisplay(tempo) {
      let minutos = Math.floor(tempo / 60000);
      let segundos = Math.floor((tempo % 60000) / 1000);
      let milesimos = tempo % 1000;

      minutos = String(minutos).padStart(2, '0');
      segundos = String(segundos).padStart(2, '0');
      milesimos = String(milesimos).padStart(3, '0');

      document.getElementById("display").textContent =
        minutos + ":" + segundos + ":" + milesimos;
    }

    function iniciar() {
      if (!rodando) {
        rodando = true;
        inicio = Date.now() - tempoDecorrido;

        intervalo = setInterval(() => {
          tempoDecorrido = Date.now() - inicio;
          atualizarDisplay(tempoDecorrido);
        }, 10);
      }
    }

    function pausar() {
      rodando = false;
      clearInterval(intervalo);
    }

    function resetar() {
      rodando = false;
      clearInterval(intervalo);
      tempoDecorrido = 0;
      atualizarDisplay(0);
    }
  </script>

</body>
</html>
